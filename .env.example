# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# AI Services - Zhipu AI (智谱AI)
VITE_ZHIPU_API_KEY=your_zhipu_api_key

# Speech Recognition - iFlytek (科大讯飞)
VITE_XUNFEI_APP_ID=your_xunfei_app_id
VITE_XUNFEI_API_KEY=your_xunfei_api_key
VITE_XUNFEI_API_SECRET=your_xunfei_api_secret

# Map Service - AMap (高德地图)
VITE_AMAP_KEY=your_amap_web_js_key
VITE_AMAP_SECURITY_JS_CODE=your_amap_security_js_code
AMAP_WEB_API_KEY=your_amap_web_service_key

# Encryption Key (for storing user API keys)
VITE_ENCRYPTION_KEY=your_encryption_key_at_least_32_characters

# Application Configuration
VITE_APP_NAME=AI Travel Planner
VITE_APP_VERSION=1.0.0
VITE_API_BASE_URL=https://your-project.supabase.co/functions/v1

# Feature Flags
VITE_ENABLE_SPEECH_RECOGNITION=true
VITE_ENABLE_DARK_MODE=true
VITE_ENABLE_MULTI_LANGUAGE=true

# Development Configuration
VITE_DEV_MODE=true
VITE_DEBUG_MODE=false

# Note:
# 1. Never commit actual .env file to version control
# 2. Copy this file to .env and fill in your actual values
# 3. For production, use environment variables in your deployment platform
# 4. API Keys should be obtained from respective service providers:
#    - Supabase: https://supabase.com/dashboard
#    - Zhipu AI: https://open.bigmodel.cn/
#    - iFlytek: https://www.xfyun.cn/
#    - AMap: https://lbs.amap.com/
